# ============================================================
# Variables de entorno para conectar Supabase.
#
# CÓMO USAR:
#   1. Copia este archivo y renómbralo a:  .env.local
#   2. Pega los valores de tu proyecto (Supabase -> Settings -> API)
#   3. Reinicia el servidor de desarrollo (npm run dev)
#
# IMPORTANTE: .env.local NUNCA se sube a Git (ya está en .gitignore).
# El prefijo NEXT_PUBLIC_ hace la variable visible en el navegador;
# la "anon key" está diseñada para eso (la seguridad real la da RLS).
# ============================================================

NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=TU_LLAVE_ANON_AQUI
